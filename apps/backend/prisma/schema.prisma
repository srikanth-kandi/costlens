// Schema: CostLens AI
// PostgreSQL via Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employee {
  id            Int                  @id @default(autoincrement())
  name          String
  email         String               @unique
  designation   String
  department    String
  hourlyRate    Float
  avatarUrl     String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  meetings      MeetingParticipant[]

  @@map("employees")
}

model Project {
  id          Int           @id @default(autoincrement())
  name        String
  code        String        @unique
  description String        @default("")
  budget      Float
  status      ProjectStatus @default(active)
  teamSize    Int?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  meetings    Meeting[]
  anomalies   Anomaly[]

  @@map("projects")
}

enum ProjectStatus {
  active
  on_hold
  completed
  at_risk
}

model Meeting {
  id              Int                  @id @default(autoincrement())
  title           String
  description     String               @default("")
  durationMinutes Int
  meetingDate     DateTime
  projectId       Int?
  confidenceScore Float                @default(0)
  cost            Float?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  project         Project?             @relation(fields: [projectId], references: [id])
  participants    MeetingParticipant[]
  anomalies       Anomaly[]

  @@map("meetings")
}

model MeetingParticipant {
  meetingId  Int
  employeeId Int
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([meetingId, employeeId])
  @@map("meeting_participants")
}

model CostSummary {
  id                 Int      @id @default(autoincrement())
  projectId          Int      @unique
  totalCost          Float    @default(0)
  meetingCount       Int      @default(0)
  hoursSpent         Float    @default(0)
  budgetUtilization  Float    @default(0)
  calculatedAt       DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("cost_summaries")
}

model Anomaly {
  id          Int            @id @default(autoincrement())
  type        AnomalyType
  severity    AnomalySeverity
  description String
  projectId   Int?
  meetingId   Int?
  amount      Float?
  detectedAt  DateTime       @default(now())
  project     Project?       @relation(fields: [projectId], references: [id])
  meeting     Meeting?       @relation(fields: [meetingId], references: [id])

  @@map("anomalies")
}

enum AnomalyType {
  budget_exceeded
  low_confidence
  expensive_meeting
  resource_imbalance
  budget_risk
}

enum AnomalySeverity {
  low
  medium
  high
  critical
}
